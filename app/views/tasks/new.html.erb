<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow">
        <div class="card-header bg-dark text-white">
          <h2 class="mb-0">Добавить задачу</h2>
        </div>
        <div class="card-body">
          <%= form_with model: @task, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :title, "Название задачи", class: "form-label" %>
              <%= f.text_field :title,
                class: ["form-control", ("is-invalid" if @task.errors[:title].any?)].compact.join(" "),
                placeholder: "Например: Купить продукты" %>
            </div>
            <div class="mb-3">
              <%= f.label :description, "Описание", class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Добавьте детали задачи" %>
            </div>
            <div class="form-check mb-3">
              <%= f.check_box :done, class: "form-check-input", id: "task_done" %>
              <%= f.label :done, "Выполнено", class: "form-check-label", for: "task_done" %>
            </div>
            <div class="d-flex justify-content-between">
              <%= f.submit "Добавить", class: "btn btn-primary" %>
              <%= link_to "Отмена", tasks_path, class: "btn btn-link" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>